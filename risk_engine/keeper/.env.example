# Network + account
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# Optional comma-separated fallbacks (used when RPC_URL is unavailable)
# BACKUP_RPC_URLS=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY,https://rpc.sepolia.org
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CHAIN_ID=11155111

# Data source
FRED_API_KEY=YOUR_FRED_API_KEY
FRED_SERIES_ID=DTB3
FRED_SECONDARY_SERIES_ID=DTB4WK
SECONDARY_SERIES_WEIGHT=0.35

# Bot tuning
BOT_INTERVAL_SECONDS=1800
TX_TIMEOUT_SECONDS=180
RPC_REQUEST_TIMEOUT_SECONDS=20
RPC_CONNECT_RETRIES=3
RPC_CONNECT_RETRY_DELAY_SECONDS=3
PRICE_CHANGE_THRESHOLD_BPS=2
YIELD_SMOOTHING_ALPHA=0.65
STALE_UPDATE_FLOOR_SECONDS=5400
FAILURE_RETRY_SECONDS=60
TBILL_FACE_VALUE_USD=1000
TBILL_TERM_DAYS=28
KEEPER_LOG_PATH=risk_engine/keeper/bot.log

